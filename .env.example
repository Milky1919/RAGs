# ── GitHub 連携設定 ────────────────────────────────────────────────────────
# GitHubのPersonal Access Token（repo権限が必要）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# リポジトリ名（例: tanaka/light-novel）
GITHUB_REPO=username/repository-name

# ── Webhook セキュリティ ──────────────────────────────────────────────────
# ローカルのgit hookと一致させること（ランダムな文字列を設定）
WEBHOOK_SECRET=change-me-to-random-secret

# ── Ollama 接続設定 ────────────────────────────────────────────────────────
# コンテナ内からホストのOllamaに接続する（基本的に変更不要）
OLLAMA_HOST=http://host.docker.internal:11434

# ── Qdrant 接続設定 ────────────────────────────────────────────────────────
# 同スタック内のqdrantサービス名（基本的に変更不要）
QDRANT_HOST=qdrant
QDRANT_PORT=6333
